{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -e '.[http,mcp]'"
  },
  "deploy": {
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port ${PORT:-8080}",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
}
