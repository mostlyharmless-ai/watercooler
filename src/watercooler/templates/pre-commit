#!/bin/bash
# Watercooler pre-commit hook for threads repositories
# Prevents committing files that exceed GitHub's 100MB limit

# Configuration
MAX_FILE_SIZE_MB=100
WARN_FILE_SIZE_MB=50
MAX_FILE_SIZE_BYTES=$((MAX_FILE_SIZE_MB * 1024 * 1024))
WARN_FILE_SIZE_BYTES=$((WARN_FILE_SIZE_MB * 1024 * 1024))

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if we should block the commit
BLOCK_COMMIT=0
WARNED=0

# Get list of files staged for commit (using -z for null-delimited output)
# This handles filenames with spaces, newlines, and special characters
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM -z)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "Checking staged files for size limits..."

# Process null-delimited file list safely
echo -n "$STAGED_FILES" | while IFS= read -r -d '' FILE; do
    # Skip if file doesn't exist (deleted file)
    if [ ! -f "$FILE" ]; then
        continue
    fi

    # Get file size using wc -c (portable across macOS and Linux)
    FILE_SIZE=$(wc -c < "$FILE" 2>/dev/null | tr -d ' ')

    if [ -z "$FILE_SIZE" ]; then
        continue
    fi

    # Check against limits
    if [ "$FILE_SIZE" -gt "$MAX_FILE_SIZE_BYTES" ]; then
        FILE_SIZE_MB=$((FILE_SIZE / 1024 / 1024))
        echo -e "${RED}ERROR: File exceeds ${MAX_FILE_SIZE_MB}MB limit:${NC}"
        echo -e "  ${FILE} (${FILE_SIZE_MB}MB)"
        echo ""
        echo "GitHub rejects files larger than 100MB."
        echo "Consider using Git LFS or adding to .gitignore."
        echo ""
        BLOCK_COMMIT=1
    elif [ "$FILE_SIZE" -gt "$WARN_FILE_SIZE_BYTES" ]; then
        FILE_SIZE_MB=$((FILE_SIZE / 1024 / 1024))
        echo -e "${YELLOW}WARNING: Large file detected:${NC}"
        echo -e "  ${FILE} (${FILE_SIZE_MB}MB)"
        WARNED=1
    fi
done

# Note: Variables set in subshell (while loop) don't persist.
# Re-check by running the same logic in main shell for the final decision.
BLOCK_COMMIT=0
echo -n "$STAGED_FILES" | while IFS= read -r -d '' FILE; do
    if [ -f "$FILE" ]; then
        FILE_SIZE=$(wc -c < "$FILE" 2>/dev/null | tr -d ' ')
        if [ -n "$FILE_SIZE" ] && [ "$FILE_SIZE" -gt "$MAX_FILE_SIZE_BYTES" ]; then
            # Use a flag file to signal blocking since we're in a subshell
            touch /tmp/.watercooler_block_commit_$$
        fi
    fi
done

if [ -f /tmp/.watercooler_block_commit_$$ ]; then
    rm -f /tmp/.watercooler_block_commit_$$
    echo -e "${RED}Commit blocked due to oversized files.${NC}"
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    echo ""
    echo "To add files to .gitignore:"
    echo "  echo 'memory/' >> .gitignore"
    echo "  git reset HEAD <file>"
    exit 1
fi

exit 0
